{
  "manifest_version": 3,
  "name": "TablahExt",
  "version": "1.1",
  "description": "AI Assessment & One-Click Job Import for Tablah",
  "permissions": [
    "activeTab",
    "tabs",
    "alarms",
    "storage",
    "scripting",
    "cookies",
    "contextMenus",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "config.js",
        "content.js"
      ]
    },
    {
      "matches": [
        "https://tablah.ai/*",
        "https://*.tablah.ai/*"
      ],
      "js": [
        "config.js",
        "auth-sync.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}